# Editor / IDE
.vscode
.idea

# Claude
.claude

# wp-content/assets source images (theme has its own copies)
assets

# Uploads — never tracked
uploads/

# Plugins + mu-plugins — exclude everything by default; opt specific ones
# back in with !plugins/<name>/ or !mu-plugins/<name>/ below. The /* glob
# is load-bearing: a bare `mu-plugins/` would block any negation inside.
plugins/*
mu-plugins/*

!mu-plugins/karkinos-gateway/

# karkinos-gateway build artefacts
mu-plugins/karkinos-gateway/vendor/
mu-plugins/karkinos-gateway/wordpress/
mu-plugins/karkinos-gateway/coverage-report/
mu-plugins/karkinos-gateway/clover.xml
mu-plugins/karkinos-gateway/coverage.xml
mu-plugins/karkinos-gateway/.phpunit.result.cache
mu-plugins/karkinos-gateway/.phpstan-cache/
mu-plugins/karkinos-gateway/tests/.env
